# Frontend (Vercel) — opcional
# Entrada directa al panel en Demo sin pantalla de login. Pon "false" cuando Schwab esté listo.
# VITE_DEMO_BYPASS=false

# Variables del SERVIDOR (Railway). El frontend (Vercel) no necesita estas.

# Charles Schwab - Trader API (Commercial)
SCHWAB_CLIENT_ID=tu_app_key
SCHWAB_CLIENT_SECRET=tu_app_secret
# Debe coincidir EXACTAMENTE con la Callback URL registrada en developer.schwab.com.
# Apunta al dominio de Vercel (que hace proxy de /api hacia este servidor en Railway).
SCHWAB_CALLBACK_URL=https://activos-trading.vercel.app/api/schwab/callback

# URL base pública del frontend (para redirecciones tras el OAuth)
APP_BASE_URL=https://activos-trading.vercel.app

# Sesión (cookie firmada). Mínimo 32 caracteres. Genera con: openssl rand -base64 32
SESSION_SECRET=

# Clave de cifrado de tokens en reposo (AES-256). 32 bytes en base64 o 64 hex.
# Genera con: openssl rand -base64 32
TOKEN_ENC_KEY=

# Neon Postgres - pooled (app en runtime)
DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require
# Neon Postgres - directa, sin -pooler (migraciones de Prisma)
DIRECT_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require

# Puerto del servidor (Railway lo inyecta automáticamente; en local usa 8080)
PORT=8080
